# SmartSell production environment
# Copy to .env.prod and fill in real values.

# Runtime mode
ENVIRONMENT=production
DEBUG=False

# Secrets (>=32 chars). Do not reuse between environments.
SECRET_KEY=replace-with-strong-secret-key-32-plus
CSRF_SECRET=replace-with-strong-csrf-secret-32-plus

# Database / Redis
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/smartsell
REDIS_URL=redis://redis:6379/0

# API base
API_V1_STR=/api/v1

# CORS / Hosts
CORS_ORIGINS=https://example.com
BACKEND_CORS_ORIGINS=https://example.com
ALLOWED_HOSTS=example.com

# Optional frontend
FRONTEND_URL=https://example.com

# Logging
LOG_LEVEL=info
TIMEZONE=UTC
