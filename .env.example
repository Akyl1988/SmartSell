# SmartSell .env.example
# Copy to .env.local (dev) or set real values via secrets in production.
# IMPORTANT: This file contains NO real secrets.

# =========================
# DEV (minimal runnable)
# =========================
ENVIRONMENT=development
DEBUG=1

# DB (use real creds in your local .env.local, do not commit)
DATABASE_URL=postgresql+asyncpg://<USER>:<PASS>@127.0.0.1:5432/smartsell_main

# Local dev defaults (no Redis required)
REDIS_DISABLED=1
REDIS_URL=disabled
RATE_LIMIT_ENABLED=0
STARTUP_LOG_SUMMARY=0

# Optional but common
PUBLIC_URL=http://localhost:8000
ALLOWED_HOSTS=["localhost","127.0.0.1"]
CORS_ORIGINS=["*"]
BACKEND_CORS_ORIGINS=["*"]
LOG_LEVEL=INFO
LOG_FORMAT=json

# =========================
# PROD (required) - set via secrets, do not commit real values
# =========================
# ENVIRONMENT=production
# SECRET_KEY=<SET_STRONG_SECRET>
# DATABASE_URL=postgresql+asyncpg://<USER>:<PASS>@<HOST>:5432/<DBNAME>
# PUBLIC_URL=https://api.example.com
# ALLOWED_HOSTS=["api.example.com"]
# PGCRYPTO_KEY=<SET_STRONG_SECRET_16PLUS>
# INTEGRATIONS_MASTER_KEY=<BASE64_KEY_FOR_PROVIDER_CONFIGS>

# =========================
# OPTIONAL (features/providers)
# =========================
APP_NAME=SmartSell
PROJECT_NAME=SmartSell
API_V1_STR=/api/v1
HOST=127.0.0.1
PORT=8000
SCHEME=http

DEBUG_CONFIG_DUMP=0

# OTP
OTP_PROVIDER=noop
OTP_ENABLED=1

# Auth TTL
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8

# Redis advanced (only if Redis used)
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CLIENT_STRICT=0
REDIS_SOCKET_TIMEOUT=1.0

# Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
SCHEDULER_TIMEZONE=UTC

# Observability
SENTRY_DSN=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TLS=1
SMTP_SSL=0

# Storage
MEDIA_DIR=media
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# Mobizon (optional)
MOBIZON_API_URL=https://api.mobizon.kz
MOBIZON_API_KEY=

# Kaspi (optional)
KASPI_AUTOSYNC_ENABLED=0
KASPI_AUTOSYNC_INTERVAL_MINUTES=15
KASPI_AUTOSYNC_MAX_CONCURRENCY=3
KASPI_API_URL=https://api.kaspi.kz
KASPI_API_KEY=
KASPI_MERCHANT_ID=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# TipTop (optional)
TIPTOP_API_URL=https://api.tippy.kz
TIPTOP_API_KEY=
TIPTOP_API_SECRET=
TIPTOP_PAY_PUBLIC_KEY=
TIPTOP_PAY_SECRET_KEY=

# =========================
# TEST ONLY (pytest)
# =========================
TEST_DATABASE_URL=postgresql+psycopg://<USER>:<PASS>@127.0.0.1:5432/smartsell_test
TEST_ASYNC_DATABASE_URL=postgresql+asyncpg://<USER>:<PASS>@127.0.0.1:5432/smartsell_test
TEST_REDIS_DISABLED=1
FORCE_INMEMORY_BACKENDS=1
PYTEST_ASYNCIO_MODE=strict
